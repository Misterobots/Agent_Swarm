{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Maintenance Manifest",
  "type": "object",
  "required": ["version", "rules"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cooldown_seconds": { "type": "integer", "minimum": 0 },
        "blast_radius": { "$ref": "#/definitions/blast_radius" }
      }
    },
    "rules": {
      "type": "array",
      "items": { "$ref": "#/definitions/rule" }
    }
  },
  "definitions": {
    "blast_radius": { "enum": ["low", "medium", "high"] },
    "rule": {
      "type": "object",
      "required": ["alert", "agent_safe"],
      "additionalProperties": false,
      "properties": {
        "alert": { "type": "string", "minLength": 1 },
        "match": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "action": {
          "enum": ["restart_container", "repair_authentik_database"]
        },
        "action_args": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "agent_safe": { "type": "boolean" },
        "blast_radius": { "$ref": "#/definitions/blast_radius" },
        "cooldown_seconds": { "type": "integer", "minimum": 0 },
        "runbook": { "type": "string" }
      },
      "allOf": [
        {
          "if": { "properties": { "agent_safe": { "const": true } }, "required": ["agent_safe"] },
          "then": { "required": ["action"] }
        }
      ]
    }
  }
}
