          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT et.id AS template,\n       COALESCE(ROUND(AVG(ph.final_score)::numeric, 3), 0) AS avg_score\nFROM swarm.expertise_templates et\nLEFT JOIN swarm.performance_history ph ON ph.template_id = et.id\n  AND ph.recorded_at > NOW() - INTERVAL '24 hours'\nGROUP BY et.id\nORDER BY avg_score DESC",
