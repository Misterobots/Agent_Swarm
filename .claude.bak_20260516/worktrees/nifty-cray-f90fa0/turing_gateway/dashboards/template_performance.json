      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "PostgreSQL-Swarm"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT et.id AS template,\n       et.name,\n       et.intent,\n       et.current_version,\n       et.default_model,\n       COALESCE(s.invocations_24h, 0) AS invocations_24h,\n       s.avg_score_24h,\n       s.avg_latency_ms,\n       s.corrector_rate\nFROM swarm.expertise_templates et\nLEFT JOIN LATERAL (\n  SELECT\n    COUNT(*) AS invocations_24h,\n    ROUND(AVG(final_score)::numeric, 3) AS avg_score_24h,\n    ROUND(AVG(latency_ms)::numeric, 0) AS avg_latency_ms,\n    ROUND(100.0 * SUM(CASE WHEN corrector_invoked THEN 1 ELSE 0 END) / NULLIF(COUNT(*), 0), 1) AS corrector_rate\n  FROM swarm.performance_history ph\n  WHERE ph.template_id = et.id\n    AND ph.recorded_at > NOW() - INTERVAL '24 hours'\n) s ON TRUE\nORDER BY s.invocations_24h DESC NULLS LAST",
          "refId": "A"
        }
      ],
      "title": "Template Performance Summary (24h)",
      "type": "table"
