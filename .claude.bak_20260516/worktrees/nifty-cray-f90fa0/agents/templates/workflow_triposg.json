{
  "10": {
    "inputs": {
      "image": "{{INPUT_IMAGE}}",
      "upload": "image"
    },
    "class_type": "LoadImage",
    "_meta": {
      "title": "Load Image"
    }
  },
  "20": {
    "inputs": {
      "model": "hunyuan3d-dit-v2-0-fp16.safetensors"
    },
    "class_type": "Hy3DModelLoader",
    "_meta": {
      "title": "Hy3D Model Loader"
    }
  },
  "30": {
    "inputs": {
      "pipeline": ["20", 0],
      "image": ["10", 0],
      "guidance_scale": "{{CFG}}",
      "steps": "{{STEPS}}",
      "seed": "{{SEED}}",
      "scheduler": "FlowMatchEulerDiscreteScheduler",
      "force_offload": true
    },
    "class_type": "Hy3DGenerateMesh",
    "_meta": {
      "title": "Hy3D Generate Mesh"
    }
  },
  "40": {
    "inputs": {
      "vae": ["20", 1],
      "latents": ["30", 0],
      "box_v": 1.01,
      "octree_resolution": 448,
      "num_chunks": 8000,
      "mc_level": 0,
      "mc_algo": "mc",
      "enable_flash_vdm": true,
      "force_offload": true
    },
    "class_type": "Hy3DVAEDecode",
    "_meta": {
      "title": "Hy3D VAE Decode"
    }
  },
  "48": {
    "inputs": {
      "trimesh": ["40", 0],
      "remove_floaters": true,
      "remove_degenerate_faces": true,
      "reduce_faces": false,
      "max_facenum": 80000,
      "smooth_normals": true
    },
    "class_type": "Hy3DPostprocessMesh",
    "_meta": {
      "title": "Hy3D Postprocess Mesh"
    }
  },
  "110": {
    "inputs": {
      "trimesh": ["48", 0],
      "filename_prefix": "3D/Hy3D_FastMesh",
      "file_format": "glb",
      "save_file": true
    },
    "class_type": "Hy3DExportMesh",
    "_meta": {
      "title": "Hy3D Export Mesh"
    }
  }
}
