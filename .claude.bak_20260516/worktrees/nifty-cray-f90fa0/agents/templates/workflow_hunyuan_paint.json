            "reduce_faces": false,
            "max_facenum": 80000,
            "smooth_normals": false
        },
        "class_type": "Hy3DPostprocessMesh",
        "_meta": {
            "title": "Hy3D Postprocess Mesh"
        }
    },
    "50": {
        "inputs": {
            "trimesh": [
                "45",
                0
            ]
        },
        "class_type": "Hy3DMeshUVWrap",
