    "26": {
        "inputs": {
            "delight_pipe": [
                "15",
                0
            ],
            "image": [
                "10",
                0
            ],
            "steps": 20,
            "width": 1024,
            "height": 1024,
            "cfg_image": 1.0,
            "seed": "{{SEED}}"
