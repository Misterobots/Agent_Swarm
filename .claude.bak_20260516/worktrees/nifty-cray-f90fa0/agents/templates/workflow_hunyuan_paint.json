    },
    "100": {
        "inputs": {
            "texture": [
                "95",
                0
            ],
            "renderer": [
                "60",
                2
            ]
        },
        "class_type": "Hy3DApplyTexture",
        "_meta": {
            "title": "Hy3D Apply Texture"
        }
