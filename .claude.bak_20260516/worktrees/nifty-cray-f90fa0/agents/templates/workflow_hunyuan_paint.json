    "110": {
        "inputs": {
            "trimesh": [
                "100",
                0
            ],
            "filename_prefix": "3D/Hunyuan_Hybrid",
            "file_format": "glb",
            "save_file": true
        },
        "class_type": "Hy3DExportMesh",
        "_meta": {
            "title": "Hy3D Export Mesh"
        }
