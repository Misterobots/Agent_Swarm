# Auto-Repair Daemon Configuration
# Copy this to .env or set as environment variables

# ═══════════════════════════════════════════════════════════════════════════════
# Node Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# Node IP addresses
TURING_IP=192.168.2.103
HOPPER_IP=192.168.2.102
LOVELACE_IP=192.168.2.101

# ═══════════════════════════════════════════════════════════════════════════════
# Authentik Database Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# Authentik Postgres credentials (required for database repair)
AUTHENTIK_DB_USER=misterobots
AUTHENTIK_DB_PASSWORD=FfyWCWx4gRZaPj1ygfjs

# ═══════════════════════════════════════════════════════════════════════════════
# Auto-Repair Behavior
# ═══════════════════════════════════════════════════════════════════════════════

# How often to check service health (seconds)
# Default: 300 (5 minutes)
AUTO_REPAIR_CHECK_INTERVAL=300

# Minimum time between repair attempts for the same service (seconds)
# Default: 600 (10 minutes)
AUTO_REPAIR_COOLDOWN=600

# Maximum consecutive failures before alerting (count)
# Default: 3
AUTO_REPAIR_MAX_FAILURES=3

# ═══════════════════════════════════════════════════════════════════════════════
# Service-Specific Settings
# ═══════════════════════════════════════════════════════════════════════════════

# Enable/disable specific repair actions (true/false)
AUTO_REPAIR_AUTHENTIK_ENABLED=true
AUTO_REPAIR_POSTGRES_ENABLED=true
AUTO_REPAIR_REDIS_ENABLED=true
AUTO_REPAIR_LANGFUSE_ENABLED=true

# Authentik-specific settings
AUTO_REPAIR_AUTHENTIK_REINDEX_ON_CORRUPTION=true
AUTO_REPAIR_AUTHENTIK_RESTART_ON_FAILURE=true

# ═══════════════════════════════════════════════════════════════════════════════
# Notification Settings (Future Enhancement)
# ═══════════════════════════════════════════════════════════════════════════════

# Send alerts on critical failures (not yet implemented)
AUTO_REPAIR_ALERT_ENABLED=false
AUTO_REPAIR_ALERT_WEBHOOK_URL=

# ═══════════════════════════════════════════════════════════════════════════════
# Logging
# ═══════════════════════════════════════════════════════════════════════════════

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
AUTO_REPAIR_LOG_LEVEL=INFO

# Keep logs for N days
AUTO_REPAIR_LOG_RETENTION_DAYS=30
