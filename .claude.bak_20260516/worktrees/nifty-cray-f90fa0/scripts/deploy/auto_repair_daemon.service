[Unit]
Description=Agent Swarm Auto-Repair Daemon
After=network.target docker.service
Requires=docker.service

[Service]
Type=simple
User=misterobots
Group=misterobots
WorkingDirectory=/home/misterobots/Home_AI_Lab/agents
Environment="PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
EnvironmentFile=-/home/misterobots/Home_AI_Lab/turing_gateway/.env
ExecStart=/usr/bin/python3 /home/misterobots/Home_AI_Lab/agents/auto_repair_daemon.py
Restart=on-failure
RestartSec=10
StandardOutput=append:/home/misterobots/Home_AI_Lab/logs/auto_repair.log
StandardError=append:/home/misterobots/Home_AI_Lab/logs/auto_repair_error.log

# Security hardening
PrivateTmp=true
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
