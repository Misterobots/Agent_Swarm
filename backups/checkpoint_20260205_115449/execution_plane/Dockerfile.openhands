FROM ghcr.io/all-hands-ai/openhands:0.9

USER root

# Install Docker using the official script (includes Buildx)
RUN apt-get update && apt-get install -y curl && \
    curl -fsSL https://get.docker.com -o get-docker.sh && \
    sh get-docker.sh && \
    rm get-docker.sh && \
    rm -rf /var/lib/apt/lists/*

# Switch back to the default user (usually 1000:1000 for OpenHands)
# Switch back to the default user is NOT needed if entrypoint handles it
# USER 1000
