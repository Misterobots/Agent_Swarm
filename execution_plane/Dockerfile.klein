# Klein Inference Service — FLUX.2 Klein via Diffusers on Blackwell (sm_120)
# Matches the PyTorch / CUDA stack used by comfyui:blackwell-sm120.

FROM nvidia/cuda:12.6.3-cudnn-runtime-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    python3.11 \
    python3.11-venv \
    python3-pip \
    git \
    wget \
    curl \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

RUN ln -sf /usr/bin/python3.11 /usr/bin/python && \
    ln -sf /usr/bin/python3.11 /usr/bin/python3

RUN python3.11 -m pip install --no-cache-dir --upgrade pip

# Blackwell (sm_120) requires PyTorch built against CUDA 13.0
RUN pip3 install --no-cache-dir \
    torch==2.11.0+cu130 \
    torchvision==0.26.0+cu130 \
    --index-url https://download.pytorch.org/whl/cu130

WORKDIR /app

COPY execution_plane/klein_service/requirements.txt .
RUN pip3 install --no-cache-dir -r requirements.txt

COPY execution_plane/klein_service/app.py .
COPY execution_plane/klein_service/schnell_transformer_config.json .

EXPOSE 8189

CMD ["uvicorn", "app:app", "--host", "0.0.0.0", "--port", "8189", "--log-level", "info"]
