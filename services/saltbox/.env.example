# ═══════════════════════════════════════════════════════════════════════════════
# Saltbox Media Server — Environment Configuration
# R730 (192.168.2.103) — saltbox Docker network
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Seafile ──────────────────────────────────────────────────────────────────
SEAFILE_MYSQL_ROOT_PASSWORD=CHANGE_ME
SEAFILE_ADMIN_EMAIL=admin@shivelymedia.com
SEAFILE_ADMIN_PASSWORD=CHANGE_ME
SEAFILE_HOSTNAME=seafile.shivelymedia.com

# ─── Romm ─────────────────────────────────────────────────────────────────────
ROMM_DB_ROOT_PASSWORD=CHANGE_ME
ROMM_DB_PASSWORD=CHANGE_ME
# Generate with: openssl rand -hex 32
ROMM_AUTH_SECRET_KEY=CHANGE_ME

# Romm library paths (adjust to your storage mounts)
ROMM_LIBRARY_PATH=/mnt/storage/roms
ROMM_ASSETS_PATH=/mnt/storage/romm-assets

# ─── Metadata Providers (optional) ────────────────────────────────────────────
# IGDB: https://api-docs.igdb.com/#getting-started
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# SteamGridDB: https://www.steamgriddb.com/profile/preferences/api
STEAMGRIDDB_API_KEY=

# Screenscraper: https://www.screenscraper.fr/
SCREENSCRAPER_USER=
SCREENSCRAPER_PASSWORD=

# RetroAchievements: https://retroachievements.org/controlpanel.php
RETROACHIEVEMENTS_API_KEY=
