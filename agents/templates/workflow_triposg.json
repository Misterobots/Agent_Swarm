{
  "10": {
    "inputs": {
      "image": "{{INPUT_IMAGE}}",
      "upload": "image"
    },
    "class_type": "LoadImage",
    "_meta": {
      "title": "Load Image"
    }
  },
  "20": {
    "inputs": {
      "image": ["10", 0]
    },
    "class_type": "TripoSGPrepareImage",
    "_meta": {
      "title": "TripoSG Prepare Image"
    }
  },
  "30": {
    "inputs": {
      "model": "VAST-AI/TripoSG"
    },
    "class_type": "TripoSGModelLoader",
    "_meta": {
      "title": "TripoSG Model Loader"
    }
  },
  "40": {
    "inputs": {
      "model": ["30", 0],
      "image": ["20", 0],
      "seed": "{{SEED}}",
      "steps": "{{STEPS}}",
      "cfg": "{{CFG}}"
    },
    "class_type": "TripoSGInference",
    "_meta": {
      "title": "TripoSG Inference (High Quality)"
    }
  },
  "45": {
    "inputs": {
      "trimesh": ["40", 0],
      "merge_vertices": true,
      "vertex_count": 50000,
      "smooth_iter": 2,
      "align_to_boundaries": true,
      "triangulate_result": true,
      "max_facenum": 80000
    },
    "class_type": "Hy3DIMRemesh",
    "_meta": {
      "title": "Instant Remesh (High Poly)"
    }
  },
  "48": {
    "inputs": {
      "trimesh": ["45", 0],
      "remove_floaters": true,
      "remove_degenerate_faces": true,
      "reduce_faces": false,
      "max_facenum": 80000,
      "smooth_normals": false
    },
    "class_type": "Hy3DPostprocessMesh",
    "_meta": {
      "title": "Remove Floating Particles"
    }
  },
  "110": {
    "inputs": {
      "trimesh": ["48", 0],
      "filename_prefix": "3D/TripoSG",
      "file_format": "glb",
      "save_file": true
    },
    "class_type": "SaveTrimesh",
    "_meta": {
      "title": "Save Trimesh (GLB)"
    }
  }
}
